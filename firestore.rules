rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==== 共用判斷 ====
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "jiahowchang@gmail.com";
    }

    // ================================================================
    // 擬真教學研究資料已於 2026-07-12 全數遷移至獨立專案 insim-research
    //（研究 App：monitor / monitor-admin / simpatient / tour / tour-editor /
    //   ventilator / survey-ai / wordcloud 都已改連新專案）
    // 以下研究集合在本專案凍結為「唯讀封存」：僅管理員可讀，全面禁寫，
    // 防止快取中的舊頁面或任何人再寫入過時資料庫
    // ================================================================
    match /wordcloud_words/{document} { allow read: if isAdmin(); allow write: if false; }
    match /ventilator_sessions/{document} { allow read: if isAdmin(); allow write: if false; }
    match /monitor_sessions/{document} { allow read: if isAdmin(); allow write: if false; }
    match /monitor_events/{document} { allow read: if isAdmin(); allow write: if false; }
    match /monitor_media/{document} { allow read: if isAdmin(); allow write: if false; }
    match /monitor_media_chunks/{document} { allow read: if isAdmin(); allow write: if false; }
    match /sim_cases/{document} { allow read: if isAdmin(); allow write: if false; }
    match /monitor_scenarios/{document} { allow read: if isAdmin(); allow write: if false; }
    match /sim_transcripts/{document} { allow read: if isAdmin(); allow write: if false; }

    // 老師帳號：已遷移至 insim-research，本專案凍結封存
    match /sim_users/{userId} { allow read: if isAdmin(); allow write: if false; }

    // 麻醉專師學習平台：使用者資料
    // - 已登入使用者只能讀寫「自己」的資料
    // - 管理員 (jiahowchang@gmail.com) 可讀寫所有人
    match /np_anesthesia_users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.email == "jiahowchang@gmail.com");
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.token.email == "jiahowchang@gmail.com" ||
         (request.auth.uid == userId &&
          // 一般使用者更新自己時，禁止改 status 欄位
          !("status" in request.resource.data.diff(resource.data).affectedKeys())));
      allow delete: if request.auth != null && request.auth.token.email == "jiahowchang@gmail.com";
    }

    // 麻醉專師學習平台：個人學習筆記
    // - doc id 格式為 {uid}__{questionId}
    // - 使用者只能讀寫自己的筆記 (資料內 uid 欄位須等於登入者)
    match /np_anesthesia_notes/{noteId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 專科護理師學習平台（六科 np-learning）：使用者資料
    // - 已登入使用者只能讀寫「自己」的資料
    // - 管理員 (jiahowchang@gmail.com) 可讀寫所有人
    match /np_learning_users/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.email == "jiahowchang@gmail.com");
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.token.email == "jiahowchang@gmail.com" ||
         (request.auth.uid == userId &&
          // 一般使用者更新自己時，禁止改 status 欄位
          !("status" in request.resource.data.diff(resource.data).affectedKeys())));
      allow delete: if request.auth != null && request.auth.token.email == "jiahowchang@gmail.com";
    }

    // 360 情境導覽（教案/進度/事件/房間）：已遷移至 insim-research，本專案凍結封存
    match /tour_defs/{document} { allow read: if isAdmin(); allow write: if false; }
    match /tour_progress/{document} { allow read: if isAdmin(); allow write: if false; }
    match /tour_events/{document} { allow read: if isAdmin(); allow write: if false; }
    match /tour_rooms/{room} {
      allow read: if isAdmin(); allow write: if false;
      match /{sub=**} { allow read: if isAdmin(); allow write: if false; }
    }

    // 家庭記帳：只有家人白名單可讀寫（之後把家人 email 加進清單）
    function isFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          "jiahowchang@gmail.com",
          "janhisuwen@gmail.com",
          "changshyanne0301@gmail.com"
        ];
    }

    // 家庭記帳：支出紀錄
    match /expense_records/{document} {
      allow read, write: if isFamily();
    }

    // 家庭記帳：貸款設定（房貸/信貸條件與手動校正）
    match /expense_loans/{document} {
      allow read, write: if isFamily();
    }

    // 課前調查問卷：已遷移至 insim-research，本專案凍結封存
    match /survey_ai_teaching/{document} { allow read: if isAdmin(); allow write: if false; }

    // 每日英語學習：每日文章（Cloud Function 以 Admin SDK 產生，前端唯讀）
    match /eng_daily/{document} {
      allow read: if true;
      allow write: if false;
    }

    // 每日英語學習：個人練習進度（doc id 為 {uid}__{date}，資料內 uid 須等於登入者）
    match /eng_progress/{docId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
