rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 你的第一個集合：任何人可讀寫
    // 之後新增工具時在這裡加更多 match 區塊
    match /wordcloud_words/{document} {
      allow read, write: if true;
    }

    // 虛擬呼吸器訓練系統：學員場次與學習軌跡
    match /ventilator_sessions/{document} {
      allow read, write: if true;
    }

    // 模擬生理監視器：iPhone 教師控制台 ↔ 監視器雙裝置同步
    match /monitor_sessions/{document} {
      allow read, write: if true;
    }

    // 模擬生理監視器：教師後台事件標記（debriefing 用）
    match /monitor_events/{document} {
      allow read, write: if true;
    }

    // 模擬生理監視器：媒體庫（影像/影音/PDF，base64 存放）
    match /monitor_media/{document} {
      allow read, write: if true;
    }

    // 媒體庫大檔分塊（>900KB 的檔案切塊存放）
    match /monitor_media_chunks/{document} {
      allow read, write: if true;
    }

    // 3D 模擬病人平台：教案
    match /sim_cases/{document} {
      allow read, write: if true;
    }

    // 其他集合預設禁止存取
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
